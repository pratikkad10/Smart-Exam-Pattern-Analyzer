# Application Settings
PORT=5000

# PostgreSQL Credentials (Used by Docker to create the database)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=sepa_db

# Prisma Database Connection String (for LOCAL development tools like `npx prisma db pull`)
# Uses 'localhost:5433' because Docker maps host port 5433 to container port 5432
DATABASE_URL="postgresql://user:password@localhost:5433/sepa_db?schema=public"
