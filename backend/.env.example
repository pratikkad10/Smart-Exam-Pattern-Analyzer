# Application Settings
PORT=5000

# PostgreSQL Credentials (Used by Docker to create the database)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=sepa_db

# Database Connection String
# Used by both Prisma CLI tools and the app runtime (parsed via Node's URL class)
# Uses 'localhost:5433' because Docker maps host port 5433 → container port 5432
DATABASE_URL=postgresql://user:password@localhost:5433/sepa_db?schema=public

# Auth Secrets
JWT_SECRET=your_secure_jwt_secret_key_here
CLIENT_URL=http://localhost:5173
