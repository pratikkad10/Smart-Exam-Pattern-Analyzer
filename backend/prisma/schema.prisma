// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------

// Defines the types of users in our system based on the PRD
enum Role {
  STUDENT
  ADMIN
}

// OAuth implementation deferred to Phase 2
// enum Provider {
//   LOCAL
//   GOOGLE
//   FACEBOOK
// }

// Defines the type of verification token
enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ------------------------------------------------------
// MODELS
// ------------------------------------------------------

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String?  // Nullable for OAuth users
  
  firstName       String
  lastName        String?
  phone           String?
  
  role            Role     @default(STUDENT)
  isEmailVerified Boolean  @default(false)
  isActive        Boolean  @default(true)
  
  // OAuth fields (for future V2 implementation)
  // provider        String   @default("LOCAL")
  // googleId        String?  @unique
  // facebookId      String?  @unique

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  tokens          VerificationToken[]
  papers          Paper[]
}

model VerificationToken {
  id        String    @id @default(uuid())
  token     String
  type      TokenType
  userId    String
  expiresAt DateTime
  
  // Relation to User
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime  @default(now())

  @@index([token, type])
}

model Paper {
  id          String     @id @default(uuid())
  title       String
  subject     String?    // e.g., "Database Management"
  year        Int?       // e.g., 2019
  fileUrl     String     // Path or URL to the uploaded PDF
  rawText     String     // The raw extracted OCR text (can be long)
  
  // Relation to User
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Relation to Questions
  questions   Question[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Question {
  id          String   @id @default(uuid())
  text        String   // The actual extracted question
  marks       Int?     // Extracted marks (e.g., 8)
  unit        String?  // Extracted unit or topic (e.g., "Unit 2")
  
  // This is where Qdrant comes in. We don't store the vector array here, 
  // but Qdrant will use this ID so we can look it up later.

  // Relation to Paper
  paperId     String
  paper       Paper    @relation(fields: [paperId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}