              "mode": "formdata",
              "formdata": [
                {
                  "key": "paper",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "title",
                  "value": "DBMS 2019 End Sem",
                  "type": "text"
                },
                {
                  "key": "subject",
                  "value": "Database Management",
