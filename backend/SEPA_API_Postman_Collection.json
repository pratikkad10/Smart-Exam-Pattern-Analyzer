            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Email Verification",
      "item": [
        {
          "name": "Verify Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/verify-email?token=paste_token_here",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "verify-email"],
              "query": [
                {
                  "key": "token",
                  "value": "paste_token_here"
                }
              ]
            }
          }
        },
        {
          "name": "Resend Verification Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
